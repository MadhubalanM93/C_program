/*Use a stack to check balanced parentheses/brackets in an expression.*/

#include<stdio.h>
char stack[100];
int top=-1;
void push(char ch)
{
stack[++top]=ch;
}
char pop()
{
if(top==-1)
{
return 0;
}
return stack[top--];
}
