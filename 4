/* Perform arithemtic operations on dynamic number of integers.*/

#include<stdio.h>
#include<stdlib.h>
int main()
{
int n;
printf("enter the value of n:");
scanf("%d",&n);
int *arr;
arr=(int *)malloc(sizeof(int));
int sum=0,product=1;
printf("enter the array elements:");
for(int i=0;i<n;i++)
{
 scanf("%d",&arr[i]);
 }
 for(int i=0;i<n;i++)
 {
 sum=sum+arr[i];
 product=product*arr[i];
 }
 printf("sum=%d\n",sum);
 
 printf("product=%d\n",product);
 return 0;
 }
 
